@model IEnumerable<FoodSafetyInspectionTracker.Models.Premises>
@{
    ViewData["Title"] = "Premises";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Premises</h2>
    @if (User.IsInRole("Admin"))
    {
        <a class="btn btn-primary" asp-action="Create">Create Premises</a>
    }
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Address</th>
            <th>Town</th>
            <th>Risk</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Address</td>
            <td>@item.Town</td>
            <td>@item.RiskRating</td>
            <td>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
